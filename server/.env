PORT=5000
DB_CONNECTION_LIMIT=50
DB_QUEUE_LIMIT=500
DB_MAX_IDLE=20
DB_IDLE_TIMEOUT=60000
FORMS_CACHE_TTL_MS=30000
FORMS_STALE_TTL_MS=300000
FORM_COUNTS_CACHE_TTL_MS=30000
FORM_COUNTS_STALE_TTL_MS=300000
BANNER_CACHE_TTL_MS=30000
BANNER_STALE_TTL_MS=300000
GZIP_MIN_BYTES=1024
DB_HOST=db_host
DB_USER=db_user
DB_PASSWORD=db_password
DB_NAME=db_name
